{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SignaVis",
  "version": "0.7.6",
  "identifier": "io.github.limitlessgreen.signavis",
  "build": {
    "frontendDist": "../_site/demo",
    "devUrl": "http://localhost:5173/demo/desktop-app.html",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:desktop"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SignaVis",
        "url": "desktop-app.html",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset:; media-src 'self' blob: asset: http://asset.localhost; connect-src 'self' asset: http://asset.localhost https://xeno-canto.org https://cdn.jsdelivr.net"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
