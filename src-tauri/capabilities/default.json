{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capabilities for the Audio Workbench main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-remove-file",
    "fs:allow-read-dir",
    "fs:allow-create-dir",
    "fs:allow-app-data-read",
    "fs:allow-app-data-write"
  ]
}
