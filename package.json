{
  "name": "audio-workbench",
  "version": "0.2.8",
  "description": "DAW-like audio player with waveform + spectrogram for analysis",
  "type": "module",
  "main": "./dist/birdnet-player.esm.js",
  "module": "./dist/birdnet-player.esm.js",
  "unpkg": "./dist/birdnet-player.iife.js",
  "types": "./types/index.d.ts",
  "files": [
    "dist/",
    "types/",
    "docs/img/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/birdnet-player.esm.js",
      "types": "./types/index.d.ts"
    },
    "./iife": "./dist/birdnet-player.iife.js",
    "./style": "./dist/birdnet-player.css"
  },
  "peerDependencies": {
    "wavesurfer.js": "^7"
  },
  "peerDependenciesMeta": {
    "wavesurfer.js": {
      "optional": true
    }
  },
  "keywords": [
    "audio",
    "spectrogram",
    "daw",
    "waveform",
    "audio-workbench"
  ],
  "author": "LimitlessGreen",
  "license": "AGPL-3.0-only",
  "homepage": "https://www.npmjs.com/package/audio-workbench",
  "bugs": {
    "url": "https://github.com/LimitlessGreen/Audio-Workbench/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LimitlessGreen/Audio-Workbench"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && node ./scripts/generate-types.js",
    "typecheck": "tsc --noEmit",
    "postinstall": "bash ./scripts/setup-git-hooks.sh 2>/dev/null || true",
    "types:generate": "node ./scripts/generate-types.js",
    "pack:check": "npm pack",
    "test": "node --test tests/*.test.mjs",
    "hooks:install": "bash ./scripts/setup-git-hooks.sh",
    "version:sync": "bash ./scripts/sync-version.sh",
    "version:check": "bash ./scripts/check-version-sync.sh",
    "release": "bash ./scripts/release.sh"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vite": "^8.0.2"
  }
}
